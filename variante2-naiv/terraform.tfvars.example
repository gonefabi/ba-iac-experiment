###############################################################################
# terraform.tfvars – Kopiere diese Datei nach terraform.tfvars
#                     und passe die Werte an dein Unternehmen an.
#
#   cp terraform.tfvars.example terraform.tfvars
#
# WICHTIG: terraform.tfvars enthält Passwörter – niemals in Git einchecken!
###############################################################################

prefix   = "meinefirma"
location = "germanywestcentral"

common_tags = {
  Umgebung  = "Produktion"
  Verwaltet = "Terraform"
  Firma     = "Meine Firma GmbH"
}

# Netzwerk
vnet_address_space    = "10.0.0.0/16"
subnet_users_prefix   = "10.0.1.0/24"
subnet_app_prefix     = "10.0.2.0/24"

# RDP-Zugang einschränken – trage hier eure Büro-IP ein!
# Beispiel: "203.0.113.50/32" für eine einzelne IP
allowed_rdp_source_ip = "203.0.113.50/32"

# Windows-VM
windows_vm_size           = "Standard_DS1_v2"
windows_admin_username    = "winadmin"
windows_admin_password    = "HIER-EIN-SICHERES-PASSWORT-EINTRAGEN!"

# Linux-VM
linux_vm_size           = "Standard_DS1_v2"
linux_admin_username    = "linuxadmin"
linux_admin_password    = "HIER-EIN-SICHERES-PASSWORT-EINTRAGEN!"
